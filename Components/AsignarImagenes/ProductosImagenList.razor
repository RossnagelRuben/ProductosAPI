@* Vista en lista de productos con selección múltiple, miniaturas y acciones masivas (SOLID: componente con una única responsabilidad de presentación). *@
@using System.Linq
@using BlazorApp_ProductosAPI.Models.AsignarImagenes
@using Microsoft.AspNetCore.Components.Web

<div class="productos-imagen-list">
    @if (IsLoading)
    {
        <div class="list-loading">
            <span class="oi oi-loop spin" aria-hidden="true"></span>
            <span>@LoadingText</span>
        </div>
    }
    else if (!Items?.Any() == true)
    {
        <div class="list-empty">
            <span class="oi oi-image" aria-hidden="true"></span>
            <p>@EmptyText</p>
        </div>
    }
    else
    {
        <div class="list-toolbar">
            <span class="list-toolbar-info">
                <strong>@(Items!.Count()) producto(s)</strong>
                @if (SelectedCount > 0)
                {
                    <span class="list-selected-badge">@SelectedCount seleccionado(s)</span>
                }
                @if (CantidadPendienteGuardar > 0)
                {
                    <span class="list-pending-badge">@CantidadPendienteGuardar imagen(es) pendiente(s)</span>
                }
                @if (CantidadObservacionesPendienteGuardar > 0)
                {
                    <span class="list-pending-badge list-pending-obs">@CantidadObservacionesPendienteGuardar observación(es) pendiente(s)</span>
                }
            </span>
            <div class="list-toolbar-actions">
                <button type="button" class="btn-list btn-bulk-serp"
                        disabled="@(IsBulkSearching || IsBulkGenerating || IsBulkGeneratingObservaciones || !TieneSeleccionados)"
                        @onclick="OnBuscarImagenMasivoClickAsync">
                    @if (IsBulkSearching)
                    {
                        <span class="oi oi-loop spin"></span>
                        <span>Buscando @(BulkSearchingTotal > 0 ? $"{BulkSearchingCurrent}/{BulkSearchingTotal}" : "")…</span>
                    }
                    else
                    {
                        <span class="oi oi-image"></span>
                        <span>Buscar imagen (API) para seleccionados</span>
                    }
                </button>
                <button type="button" class="btn-list btn-bulk-gemini"
                        disabled="@(IsBulkSearching || IsBulkGenerating || IsBulkGeneratingObservaciones || !TieneSeleccionados)"
                        @onclick="(() => OnGenerarImagenMasivo.InvokeAsync())">
                    @if (IsBulkGenerating)
                    {
                        <span class="oi oi-loop spin"></span>
                        <span>Generando @(BulkGeneratingTotal > 0 ? $"{BulkGeneratingCurrent}/{BulkGeneratingTotal}" : "")…</span>
                    }
                    else
                    {
                        <span class="oi oi-plus"></span>
                        <span>Generar imagen (Gemini) para seleccionados</span>
                    }
                </button>
                @* Botón SerpAPI+Gemini oculto: solo se usa OpenAI para observaciones.
                <button type="button" class="btn-list btn-bulk-obs"
                        disabled="@(IsBulkSearching || IsBulkGenerating || IsBulkGeneratingObservaciones || !TieneSeleccionados)"
                        @onclick="(() => OnGenerarObservacionesMasivo.InvokeAsync())">
                    @if (IsBulkGeneratingObservaciones)
                    {
                        <span class="oi oi-loop spin"></span>
                        <span>Observaciones @(BulkGeneratingObservacionesTotal > 0 ? $"{BulkGeneratingObservacionesCurrent}/{BulkGeneratingObservacionesTotal}" : "")…</span>
                    }
                    else
                    {
                        <span class="oi oi-document"></span>
                        <span>Generar observaciones (SerpAPI+Gemini)</span>
                    }
                </button>
                *@
                <button type="button" class="btn-list btn-bulk-obs"
                        disabled="@(IsBulkSearching || IsBulkGenerating || IsBulkGeneratingObservaciones || !TieneSeleccionados)"
                        @onclick="(() => OnGenerarObservacionesMasivoOpenAI.InvokeAsync())">
                    <span class="oi oi-document"></span>
                    <span>Generar observaciones (OpenAI)</span>
                </button>
                <button type="button" class="btn-list btn-save-all"
                        disabled="@(TotalPendienteGuardar == 0 || IsGuardandoTodos)"
                        @onclick="(() => OnGuardarCambios.InvokeAsync())">
                    @if (IsGuardandoTodos)
                    {
                        <span class="oi oi-loop spin"></span>
                        <span>Guardando…</span>
                    }
                    else
                    {
                        <span class="oi oi-check"></span>
                        <span>Guardar cambios</span>
                    }
                </button>
            </div>
        </div>

        <div class="list-table-wrap">
            <table class="list-table">
                <thead>
                    <tr>
                        <th class="list-th-check">
                            <input type="checkbox" aria-label="Seleccionar todos"
                                   checked="@TodosSeleccionados"
                                   @onchange="OnToggleTodosClick" />
                        </th>
                        <th class="list-th-img">Imagen</th>
                        <th class="list-th-desc">Descripción</th>
                        <th class="list-th-meta">Código / Código de barra</th>
                        <th class="list-th-actions">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Items!)
                    {
                        <tr class="@(p.ImagenPendienteGuardar ? "list-row-pending" : "")" @key="p.ProductoID">
                            <td class="list-td-check">
                                <input type="checkbox" aria-label="Seleccionar @(p.DescripcionLarga ?? p.Codigo)"
                                       checked="@IsSelected(p.ProductoID)"
                                       @onchange="() => OnToggleSeleccion.InvokeAsync(p)" />
                            </td>
                            <td class="list-td-img">
                                <button type="button" class="list-thumb-btn"
                                        @onclick="() => OnAbrirPreviewImagen.InvokeAsync(p)"
                                        title="Ver imagen">
                                    <img src="@GetThumbSrc(p)"
                                         alt=""
                                         loading="lazy"
                                         referrerpolicy="no-referrer"
                                         class="list-thumb" />
                                </button>
                            </td>
                            <td class="list-td-desc">
                                <span class="list-desc">@(p.DescripcionLarga ?? "—")</span>
                                @if (p.ImagenPendienteGuardar)
                                {
                                    <span class="list-pending-dot" title="Pendiente de guardar">●</span>
                                }
                            </td>
                            <td class="list-td-meta">
                                @if (!string.IsNullOrWhiteSpace(p.RubroCodigo))
                                {
                                    <strong class="list-rubro">@p.RubroCodigo</strong>
                                }
                                @if (!string.IsNullOrWhiteSpace(p.RubroCodigo) && !string.IsNullOrWhiteSpace(p.CodigoBarra))
                                {
                                    <span class="list-meta-sep"> · </span>
                                }
                                @if (!string.IsNullOrWhiteSpace(p.CodigoBarra))
                                {
                                    <span class="list-barcode">@p.CodigoBarra</span>
                                }
                            </td>
                            <td class="list-td-actions">
                                <button type="button" class="btn-list btn-sm btn-ver"
                                        @onclick="() => OnAbrirModalImagen.InvokeAsync(p)">
                                    <span class="oi oi-image"></span> @(TieneImagenReal(p) ? "Ver / Mejorar" : "Generar")
                                </button>
                                @* Botón SerpAPI original (se reutiliza para disparar la búsqueda vía API interna).
                                Mantener este bloque si en el futuro se quiere volver a SerpAPI externa.
                                *@
                                @if (PuedeBuscarEnWeb(p))
                                {
                                    <button type="button" class="btn-list btn-sm btn-serp"
                                            @onclick="() => OnBuscarImagenSerpApi.InvokeAsync(p)">
                                        <span class="oi oi-magnifying-glass"></span> Buscar imagen (API)
                                    </button>
                                }
                                <button type="button" class="btn-list btn-sm btn-obs"
                                        @onclick="() => OnAbrirModalObservaciones.InvokeAsync(p)">
                                    <span class="oi oi-document"></span> Observaciones
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<style>
    .productos-imagen-list {
        min-height: 200px;
        padding: 0.5rem 0;
        background: #fff;
        border-radius: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        border: 1px solid #e9ecef;
    }
    .list-loading, .list-empty {
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        padding: 3rem 1rem; color: #6c757d; gap: 0.75rem;
    }
    .list-empty { color: #495057; }
    .list-toolbar {
        display: flex; flex-wrap: wrap; align-items: center; gap: 1rem;
        padding: 0.75rem 1rem; margin-bottom: 0.5rem; border-bottom: 1px solid #e9ecef;
        background: #fff; color: #212529;
    }
    .list-toolbar-info { display: flex; align-items: center; gap: 0.5rem; color: #212529; }
    .list-selected-badge {
        background: #0d6efd;
        color: #fff;
        padding: 0.2rem 0.5rem;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 500;
    }
    .list-pending-badge {
        background: #ffc107; color: #000; padding: 0.2rem 0.5rem; border-radius: 6px;
        font-size: 0.85rem; font-weight: 500;
    }
    .list-pending-obs { background: #6f42c1; color: #fff; }
    .list-toolbar-actions { display: flex; flex-wrap: wrap; gap: 0.85rem; }
    .btn-list {
        display: inline-flex; align-items: center; gap: 0.35rem;
        padding: 0.5rem 0.75rem; border-radius: 8px; border: none;
        font-size: 0.9rem; cursor: pointer; transition: opacity 0.2s, background 0.2s;
    }
    .btn-list:disabled { opacity: 0.7; cursor: not-allowed; }
    .btn-bulk-serp { background: #0d6efd; color: #fff; }
    .btn-bulk-serp:hover:not(:disabled) { background: #0b5ed7; }
    .btn-bulk-gemini { background: #6f42c1; color: #fff; }
    .btn-bulk-gemini:hover:not(:disabled) { background: #5a32a3; }
    .btn-bulk-obs { background: #6f42c1; color: #fff; }
    .btn-bulk-obs:hover:not(:disabled) { background: #5a32a3; }
    .btn-save-all { background: #198754; color: #fff; }
    .btn-save-all:hover:not(:disabled) { background: #157347; }
    .btn-ver { background: #0d6efd; color: #fff; }
    .btn-serp { background: #0d6efd; color: #fff; }
    .btn-obs { background: #6f42c1; color: #fff; }
    .btn-sm { padding: 0.35rem 0.6rem; font-size: 0.8rem; }
    .list-table-wrap {
        overflow-x: auto;
        background: #fff;
        border-radius: 0 0 12px 12px;
    }
    .list-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 0.9rem;
        background: #fff;
    }
    .list-table thead {
        background: #f8f9fa;
        color: #212529;
    }
    .list-table th {
        padding: 0.65rem 0.85rem;
        text-align: left;
        border-bottom: 2px solid #dee2e6;
        vertical-align: middle;
        font-weight: 600;
        color: #212529;
    }
    .list-table tbody tr {
        background: #fff;
        box-shadow: 0 1px 0 0 #e9ecef;
    }
    .list-table tbody tr:hover {
        background: #f8f9fa;
    }
    .list-table td {
        padding: 0.6rem 0.85rem;
        text-align: left;
        border-bottom: 1px solid #e9ecef;
        vertical-align: middle;
        color: #212529;
    }
    .list-th-check, .list-td-check { width: 2.5rem; }
    .list-th-img, .list-td-img { width: 80px; }
    .list-th-desc, .list-td-desc { min-width: 200px; color: #1a1a2e; }
    .list-th-meta, .list-td-meta { min-width: 120px; color: #495057; font-size: 0.85rem; }
    .list-th-actions, .list-td-actions { white-space: nowrap; }
    .list-td-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        align-items: center;
    }
    .list-thumb-btn {
        padding: 0; border: 1px solid #dee2e6; border-radius: 8px;
        background: #f8f9fa; cursor: pointer; display: block; overflow: hidden;
        width: 56px; height: 56px;
    }
    .list-thumb-btn:hover { border-color: #0d6efd; box-shadow: 0 0 0 2px rgba(13,110,253,0.2); }
    .list-thumb { width: 100%; height: 100%; object-fit: contain; }
    .list-desc { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; color: #1a1a2e; }
    .list-pending-dot { color: #ffc107; margin-left: 0.25rem; }
    .list-rubro { margin-right: 0.35rem; }
    .list-meta-sep { color: #adb5bd; margin: 0 0.25rem; font-weight: normal; }
    .list-barcode { font-family: monospace; font-size: 0.85rem; color: #495057; }
    .list-row-pending { background: #fffde7 !important; }
    .oi.spin { animation: spin 0.8s linear infinite; }
    @@keyframes spin { to { transform: rotate(360deg); } }
    @@media (max-width: 768px) {
        .list-toolbar { flex-direction: column; align-items: flex-start; }
        .list-table { font-size: 0.85rem; }
        .list-td-actions { white-space: normal; }
        .btn-sm { margin-bottom: 0.25rem; }
    }
</style>
