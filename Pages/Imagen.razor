    // ===== MANEJO SEGURO DE CARGA DE IMAGEN =====
    private async Task OnImageLoaded()
    {
        try
        {
            Console.WriteLine("🖼️ OnImageLoaded: Iniciando medición de imagen...");
            
            // ===== Verificar que la imagen esté disponible =====
            if (ImageBytes == null || ImageDataUrl == null)
            {
                Console.WriteLine("⚠️ OnImageLoaded: Imagen no disponible, saltando medición");
                return;
            }

            // ===== Intentar obtener dimensiones de la imagen =====
            try
            {
                var s = await JS.InvokeAsync<DomSize2>("getImageSizes", "#ocr-img");
                
                if (s != null)
                {
                    NaturalW = s.NaturalWidth;
                    NaturalH = s.NaturalHeight;
                    
                    Console.WriteLine($"📏 OnImageLoaded: Dimensiones obtenidas - Natural: {NaturalW}x{NaturalH}, Client: {s.ClientWidth}x{s.ClientHeight}");
                    
                    // ===== Intentar ajustar el overlay SVG =====
                    try
                    {
                        await JS.InvokeVoidAsync("sizeSvgOverImage", ".overlay",
                            s.ClientWidth, s.ClientHeight, s.NaturalWidth, s.NaturalHeight);
                        Console.WriteLine("✅ OnImageLoaded: Overlay SVG ajustado correctamente");
                    }
                    catch (Exception exSvg)
                    {
                        Console.WriteLine($"⚠️ OnImageLoaded: Error al ajustar overlay SVG: {exSvg.Message}");
                        // No es crítico, continuar
                    }
                }
                else
                {
                    Console.WriteLine("⚠️ OnImageLoaded: getImageSizes retornó null");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"⚠️ OnImageLoaded: Error al obtener dimensiones: {ex.Message}");
                // No es crítico, continuar sin dimensiones
            }
        }
        catch (Exception ex)
        {
            // ===== Captura de excepciones generales =====
            Console.WriteLine($"❌ OnImageLoaded: Error general: {ex.Message}");
            Console.WriteLine($"📚 StackTrace: {ex.StackTrace}");
            
            // ===== Mostrar error no crítico al usuario =====
            Error = $"⚠️ No se pudo medir completamente la imagen: {ex.Message}. La funcionalidad básica seguirá funcionando.";
        }
        finally
        {
            // ===== UI se actualiza automáticamente =====
            Console.WriteLine("✅ OnImageLoaded: Completado");
        }
    }

    // === Normalización (0..1 → px naturales) ===
    private static bool LooksNormalized(List<Pt> pts)
        => pts.Count > 0 && pts.All(p => p.X >= 0 && p.Y >= 0 && p.X <= 1.05 && p.Y <= 1.05);

    private static List<Pt> NormalizeIfNeeded(List<Pt> pts, double naturalW, double naturalH)
    {
        if (naturalW <= 0 || naturalH <= 0) return pts;
        if (!LooksNormalized(pts)) return pts;
        return pts.Select(p => new Pt(
            (float)(p.X * naturalW),
            (float)(p.Y * naturalH)
        )).ToList();
    }

    // DTO para JS interop
    private sealed class DomSize2
    {
        public double ClientWidth { get; set; }
        public double ClientHeight { get; set; }
        public double NaturalWidth { get; set; }
        public double NaturalHeight { get; set; }
    }

    private static string TryParseGemini(string responseJson)
    {
        Console.WriteLine($"🔍 TryParseGemini: INICIANDO - Longitud: {responseJson?.Length ?? 0}");
        
        try
        {
            using var doc = JsonDocument.Parse(responseJson);
            var root = doc.RootElement;
            
            Console.WriteLine($"📋 TryParseGemini: Root parseado correctamente");
            
            var candidates = root.GetProperty("candidates");
            if (candidates.ValueKind != JsonValueKind.Array || candidates.GetArrayLength() == 0)
            {
                Console.WriteLine("⚠️ TryParseGemini: No hay candidates válidos, retornando responseJson");
                return responseJson;
            }
            
            Console.WriteLine($"✅ TryParseGemini: Candidates encontrados: {candidates.GetArrayLength()}");
            
            var parts = candidates[0].GetProperty("content").GetProperty("parts");
            if (parts.ValueKind != JsonValueKind.Array || parts.GetArrayLength() == 0)
            {
                Console.WriteLine("⚠️ TryParseGemini: No hay parts válidos, retornando responseJson");
                return responseJson;
            }
            
            Console.WriteLine($"✅ TryParseGemini: Parts encontrados: {parts.GetArrayLength()}");
            
            var text = parts[0].GetProperty("text").GetString() ?? "";
            Console.WriteLine($"📝 TryParseGemini: Texto extraído - Longitud: {text.Length}");
            Console.WriteLine($"📝 TryParseGemini: Texto extraído - Contenido: '{text}'");
            
            var start = text.IndexOf('[');
            var end = text.LastIndexOf(']');
            
            Console.WriteLine($"🔍 TryParseGemini: Posiciones [ y ] - start: {start}, end: {end}");
            
            if (start >= 0 && end > start)
            {
                var result = text.Substring(start, end - start + 1).Trim();
                Console.WriteLine($"✅ TryParseGemini: JSON extraído - Longitud: {result.Length}");
                Console.WriteLine($"✅ TryParseGemini: JSON extraído - Contenido: '{result}'");
                return result;
            }
            
            Console.WriteLine($"⚠️ TryParseGemini: No se encontraron corchetes, retornando texto completo");
            return text.Trim();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ TryParseGemini: EXCEPCIÓN: {ex.Message}");
            Console.WriteLine($"📚 StackTrace: {ex.StackTrace}");
            return responseJson;
        }
    }

