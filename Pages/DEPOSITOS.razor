    private IEnumerable<ProductoStock> FilterProductos()
    {
        var data = productosSeleccionados.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(filtroTexto))
        {
            var t = filtroTexto.Trim().ToLowerInvariant();
            data = data.Where(p => (p.Producto.DescripcionLarga ?? string.Empty).ToLowerInvariant().Contains(t));
        }
        if (!string.IsNullOrWhiteSpace(filtroRubro))
        {
            var r = filtroRubro.Trim().ToLowerInvariant();
            data = data.Where(p => (p.Producto.RubroCodigo ?? string.Empty).ToLowerInvariant().Contains(r));
        }
        return data;
    }

