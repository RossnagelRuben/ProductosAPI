    // Función para manejar el toggle del panel de ubicaciones
    window.toggleLocationsPanel = function (isHidden) {
        const leftPanel = document.querySelector('.left-panel');
        const rightPanel = document.querySelector('.right-panel');
        const resizeHandle = document.querySelector('.resize-handle');
        
        if (leftPanel && rightPanel) {
            if (isHidden) {
                // Ocultar panel de ubicaciones
                leftPanel.style.display = 'none';
                leftPanel.style.width = '0';
                leftPanel.style.flex = 'none';
                leftPanel.classList.add('panel-hidden');
                
                // Verificar si el panel de productos también está oculto
                const isRightPanelHidden = rightPanel.classList.contains('panel-hidden') || 
                                         rightPanel.style.display === 'none';
                
                if (isRightPanelHidden) {
                    // Si ambos están ocultos, no mostrar ninguno
                    rightPanel.style.display = 'none';
                    rightPanel.style.width = '0';
                    rightPanel.style.flex = 'none';
                } else {
                    // Si solo ubicaciones está oculto, mostrar productos al 100%
                    rightPanel.style.display = 'flex';
                    rightPanel.style.width = '100%';
                    rightPanel.style.flex = '1';
                    rightPanel.style.minWidth = '100%';
                    rightPanel.style.maxWidth = '100%';
                    rightPanel.classList.remove('panel-hidden');
                }
                
                // Ocultar la barra divisoria
                if (resizeHandle) {
                    resizeHandle.style.display = 'none';
                    resizeHandle.style.width = '0';
                }
            } else {
                // Mostrar panel de ubicaciones
                leftPanel.style.display = 'flex';
                leftPanel.style.width = '35%';
                leftPanel.style.flex = 'none';
                leftPanel.style.minWidth = '280px';
                leftPanel.style.maxWidth = '70%';
                leftPanel.classList.remove('panel-hidden');
                
                // Verificar si el panel de productos está oculto
                const isRightPanelHidden = rightPanel.classList.contains('panel-hidden') || 
                                         rightPanel.style.display === 'none';
                
                if (isRightPanelHidden) {
                    // Si productos está oculto, mantenerlo oculto
                    rightPanel.style.display = 'none';
                    rightPanel.style.width = '0';
                    rightPanel.style.flex = 'none';
                } else {
                    // Si productos está visible, restaurar layout normal
                    rightPanel.style.width = '65%';
                    rightPanel.style.flex = 'none';
                    rightPanel.style.minWidth = '30%';
                    rightPanel.style.maxWidth = 'none';
                }
                
                // Mostrar la barra divisoria solo si ambos paneles están visibles
                if (resizeHandle) {
                    if (!isRightPanelHidden) {
                        resizeHandle.style.display = 'block';
                        resizeHandle.style.width = '4px';
                    } else {
                        resizeHandle.style.display = 'none';
                        resizeHandle.style.width = '0';
                    }
                }
            }
        }
