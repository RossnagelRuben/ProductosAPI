    // Modal Rubro/Familia - basado en valores únicos de productos cargados
    private IEnumerable<string> GetRubrosFiltrados()
    {
        // Si hay familias desde API, usar esas descripciones; sino, derivar de RubroCodigo de productos
        IEnumerable<string> baseList = familias != null && familias.Count > 0
            ? familias.Select(f => f.Descripcion)
            : productosSeleccionados
                .Select(p => p.Producto.RubroCodigo ?? string.Empty)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .Distinct();
        baseList = baseList.OrderBy(s => s);
        if (string.IsNullOrWhiteSpace(filtroRubroBuscar)) return baseList;
        var t = filtroRubroBuscar.Trim().ToLowerInvariant();
        return baseList.Where(s => s.ToLowerInvariant().Contains(t));
    }

    private void SeleccionarRubro(string rubro)
    {
        filtroRubro = rubro;
        showRubroModal = false;
    }
