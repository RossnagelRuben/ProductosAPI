                rightPanel.style.display = 'none !important';
                rightPanel.style.width = '0 !important';
                rightPanel.style.height = '0 !important';
                rightPanel.style.overflow = 'hidden !important';
                rightPanel.style.visibility = 'hidden !important';
            } else {
                rightPanel.style.display = '';
                rightPanel.style.width = '';
                rightPanel.style.height = '';
                rightPanel.style.overflow = '';
                rightPanel.style.visibility = '';
            }
        }

        // Ocultar/mostrar resize handle
        const resizeHandle = document.querySelector('.resize-handle');
        if (resizeHandle) {
            if (isMobile) {
                resizeHandle.style.display = 'none !important';
            } else {
                resizeHandle.style.display = '';
            }
        }

        // Forzar que el panel izquierdo ocupe toda la pantalla en móviles
        const leftPanel = document.querySelector('.left-panel');
        if (leftPanel) {
            if (isMobile) {
