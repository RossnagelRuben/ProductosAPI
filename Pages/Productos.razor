        border: 1px solid #e3e3e3;
        border-radius: 10px;
    }

    .thead {
        font-weight: 700;
        background: #fff;
    }

    .row {
        background: #fff;
    }

    .pager {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 12px;
    }

        .pager button {
            padding: 6px 10px;
            border-radius: 8px;
            border: 1px solid #ccc;
            background: #f7f7f7;
            cursor: pointer;
        }

    .error {
        color: #c00;
        white-space: pre-wrap;
    }
</style>
