            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="Empresas">
                <span class="oi oi-briefcase" aria-hidden="true"></span> Datos Empresa
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="Imagen">
                <span class="oi oi-camera-slr" aria-hidden="true"></span> Analizar Imagen
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="DEPOSITOS">
                <span class="oi oi-location" aria-hidden="true"></span> Stock por Ubicación
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="Publicidad">
                <span class="oi oi-camera-slr" aria-hidden="true"></span> PUBLICIDAD
            </NavLink>
        </div>

    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
